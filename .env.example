# Copy to .env and fill in real values before `docker-compose up`.

# PostgreSQL credentials (used by the postgres container and the backend)
POSTGRES_USER=gradus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gradus

# Secret for signing auth tokens. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Origin allowed to call the API (the address you open the app at)
CORS_ORIGIN=http://localhost:3000

# Set to true when serving behind HTTPS — see "Production deployment" in the README
COOKIE_SECURE=false
